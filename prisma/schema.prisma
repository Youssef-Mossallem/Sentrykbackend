generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================
enum Role {
  ADMIN
  SECRETARY
}

enum Stage {
  PRIMARY
  MIDDLE
  HIGH
}

enum SubscriptionType {
  MONTHLY
  HALF_MONTH
  COURSE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum SmsTransactionType {
  CHARGE
  SEND
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// =============================================
// MODELS
// =============================================

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  password             String
  role                 Role
  centerId             Int
  isActive             Boolean   @default(true)
  resetToken           String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  center               Center         @relation(fields: [centerId], references: [id], onDelete: Cascade)
  activityLogs         ActivityLog[]
  createdSubscriptions Subscription[] @relation("CreatedSubscriptions")
  payments             Payment[]
}

model Center {
  id             Int       @id @default(autoincrement())
  name           String
  phone          String

  plan           String    @default("TRIAL")
  trialUsed      Boolean   @default(false)
  trialStartedAt DateTime?

  referralCode   String?   @unique
  referralCount  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users          User[]
  students       Student[]
  groups         Group[]
  subjects       Subject[]
  activityLogs   ActivityLog[]
  smsWallet      SmsWallet?
  subscriptions  CenterSubscription[]
  payments       Payment[]
}

model Student {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  stage       Stage
  groupId     Int?
  centerId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  group       Group?   @relation(fields: [groupId], references: [id])
  subscriptions Subscription[]
}

model Group {
  id             Int      @id @default(autoincrement())
  name           String
  centerId       Int
  parentGroupId  Int?
  maxStudents    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  center         Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  parentGroup    Group?   @relation("SubGroups", fields: [parentGroupId], references: [id])
  subGroups      Group[]  @relation("SubGroups")
  students       Student[]
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String
  centerId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  prices      SubjectPrice[]
  subscriptionItems SubscriptionItem[]
}

model CenterSubscription {
  id        Int      @id @default(autoincrement())
  centerId  Int
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)

  payments  Payment[] @relation("SubToPayments")
  center    Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    Int           @id @default(autoincrement())
  centerId              Int
  centerSubscriptionId  Int?

  amount                Float
  plan                  String?

  paymentMethod         String?       @default("PAYMOB_FLASH")

  transactionId         String?       @unique
  paymobIntentionId     String?       @unique

  merchantReference     String?

  status                PaymentStatus @default(PENDING)

  createdBy             Int?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  paidAt                DateTime?

  metadata              Json?

  center               Center              @relation(fields: [centerId], references: [id], onDelete: Cascade)
  createdByUser        User?               @relation(fields: [createdBy], references: [id])
  centerSubscription   CenterSubscription? @relation("SubToPayments", fields: [centerSubscriptionId], references: [id])
  smsTransactions      SmsTransaction[]
}

model SubjectPrice {
  id               Int              @id @default(autoincrement())
  subjectId        Int
  stage            Stage
  subscriptionType SubscriptionType
  price            Float
  durationInMonths Int?
  activeFrom       DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  subject          Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, stage, subscriptionType])
}

model Subscription {
  id                Int                @id @default(autoincrement())
  studentId         Int
  startDate         DateTime           @default(now())
  endDate           DateTime
  status            SubscriptionStatus @default(ACTIVE)
  totalPrice        Float
  subscriptionType  SubscriptionType
  createdBy         Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  student           Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdByUser     User?              @relation("CreatedSubscriptions", fields: [createdBy], references: [id])
  items             SubscriptionItem[]
}

model SubscriptionItem {
  id             Int          @id @default(autoincrement())
  subscriptionId Int
  subjectId      Int
  priceSnapshot  Float

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id])
}

model SmsWallet {
  id        Int      @id @default(autoincrement())
  centerId  Int      @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  transactions SmsTransaction[]
}

model SmsTransaction {
  id          Int                @id @default(autoincrement())
  walletId    Int
  amount      Int
  type        SmsTransactionType
  description String?
  paymentId   Int?
  createdAt   DateTime           @default(now())

  wallet      SmsWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment     Payment?           @relation(fields: [paymentId], references: [id])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  centerId    Int
  userId      Int
  action      String
  targetType  String
  targetId    Int?
  details     String?
  createdAt   DateTime @default(now())

  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}