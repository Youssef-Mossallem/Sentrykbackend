generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================
enum Role {
  ADMIN
  SECRETARY
}

enum Stage {
  PRIMARY // ابتدائي
  MIDDLE  // إعدادي
  HIGH    // ثانوي
}

enum SubscriptionType {
  PER_SESSION
  MONTHLY
  HALF_MONTH
  COURSE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum WhatsAppTransactionType {
  CHARGE
  SEND
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum BillingCycle {
  MONTHLY
  YEARLY
  BOTH
}

// =============================================
// MODELS
// =============================================

model User {
  id                   Int           @id @default(autoincrement())
  name                 String
  email                String        @unique
  password             String
  role                 Role
  centerId             Int
  isActive             Boolean       @default(true)
  resetToken           String?
  resetTokenExpiry     DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  center               Center        @relation(fields: [centerId], references: [id], onDelete: Cascade)
  activityLogs         ActivityLog[]
  createdSubscriptions Subscription[] @relation("CreatedSubscriptions")
  payments             Payment[]
}

model Center {
  id             Int       @id @default(autoincrement())
  name           String
  phone          String
  plan           String    @default("null") // مثل: BASIC, PREMIUM, TRIAL
  trialUsed      Boolean   @default(false)
  trialStartedAt DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 1. حدود نظام الـ SaaS للتحكم الكامل
  maxStudents Int @default(0) 
  maxUsers    Int @default(1) 

  // 2. هندسة نظام الإحالة المتطور (Referral System)
  referralCode  String? @unique 
  referralCount Int     @default(0) 

  referredById    Int?
  referredBy      Center?  @relation("CenterReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredCenters Center[] @relation("CenterReferrals")

  referralMilestoneAchieved Boolean @default(false) 

  // 3. 🛡️ نظام تتبع أكواد الخصم المستمرة وإمكانية إيقافها يدوياً للسنتر
  activePromoCodeId Int? 
  activePromoCode   PromoCode? @relation("CenterActivePromo", fields: [activePromoCodeId], references: [id], onDelete: SetNull)
  promoMonthsUsed   Int        @default(0) 
  promoAppliedAt    DateTime? 
  isPromoPaused     Boolean    @default(false) // ميزة التحكم الذكي الجديدة

  // العلاقات العامة للسنتر
  users             User[]
  students          Student[]
  rooms             Room[]
  teachers          Teacher[]
  activityLogs      ActivityLog[]
  whatsappWallet    WhatsAppWallet?
  subscriptions     CenterSubscription[]
  payments          Payment[]
  attendance        Attendance[]
  monthlyReportLogs MonthlyReportLog[]
  attendanceScans   AttendanceScan[]
  shortLinks        ShortLink[]
  pendingFreeMonths Int                @default(0)
  planExpiresAt     DateTime?
}

model Student {
  id                Int                @id @default(autoincrement())
  name              String
  phone             String
  stage             String 
  grade             Int
  centerId          Int
  qrToken           String             @unique @default(uuid())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  center            Center             @relation(fields: [centerId], references: [id], onDelete: Cascade)
  subscriptions     Subscription[]
  attendance        Attendance[]
  monthlyReportLogs MonthlyReportLog[]
  attendanceScans   AttendanceScan[]
  qrImageUrl        String?
}

model Room {
  id          Int       @id @default(autoincrement())
  name        String    
  maxStudents Int       @default(60)
  centerId    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  center      Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  sessions    Session[]
}

model Teacher {
  id           Int                  @id @default(autoincrement())
  name         String
  subject      String
  phone        String?
  centerId     Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  center       Center               @relation(fields: [centerId], references: [id], onDelete: Cascade)
  sessions     Session[]
  priceConfigs PriceConfiguration[]
}

model Session {
  id                Int                       @id @default(autoincrement())
  name              String
  teacherId         Int
  roomId            Int
  days              String[]                  // مثل ["Saturday", "Wednesday"]
  startTime         String
  endTime           String
  maxStudents       Int
  stage             Stage
  grade             Int
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  teacher           Teacher                   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room              Room                      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  attendance        Attendance[]
  attendanceWindows SessionAttendanceWindow[]
  subscriptionItems SubscriptionItem[]
}

model PriceConfiguration {
  id               Int              @id @default(autoincrement())
  teacherId        Int
  stage            Stage
  grades           Int[]
  subscriptionType SubscriptionType
  price            Float            // سعر الحصة الواحدة، أو الشهر، أو الكورس بالكامل
  
  // ✨ حقول جديدة مضافة لإصلاح النقص في منطق المدد
  durationMonths   Int?             // مدة الكورس بالشهور (تستخدم لو نوع الاشتراك COURSE)
  totalSessions    Int?             // عدد الحصص الافتراضي لهذه الحزمة إن وجد

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  teacher          Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model MonthlyReportLog {
  id           Int      @id @default(autoincrement())
  studentId    Int
  centerId     Int
  month        Int
  year         Int
  totalPresent Int
  totalAbsent  Int
  totalLate    Int
  sentAt       DateTime @default(now())
  status       String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  center       Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([studentId, month, year])
  @@index([centerId])
}

model CenterSubscription {
  id        Int       @id @default(autoincrement())
  centerId  Int
  startDate DateTime  @default(now())
  endDate   DateTime
  isActive  Boolean   @default(true)
  payments  Payment[] @relation("SubToPayments")
  center    Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    Int                 @id @default(autoincrement())
  centerId              Int
  centerSubscriptionId  Int?
  promoCodeId           Int? 
  amount                Float
  plan                  String?
  paymentMethod         String?             @default("PAYMOB_FLASH")
  transactionId         String?             @unique
  paymobIntentionId     String?             @unique
  merchantReference     String?
  status                PaymentStatus       @default(PENDING)
  createdBy             Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  paidAt                DateTime?
  metadata              Json?

  billingCycle          BillingCycle?       
  durationMonths        Int                 @default(1) 
  planPrice             Float?              
  activatedAt           DateTime?           
  processedAt           DateTime?           

  center                Center              @relation(fields: [centerId], references: [id], onDelete: Cascade)
  createdByUser         User?               @relation(fields: [createdBy], references: [id])
  centerSubscription    CenterSubscription? @relation("SubToPayments", fields: [centerSubscriptionId], references: [id])
  promoCode             PromoCode?          @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  whatsappTransactions  WhatsAppTransaction[]

  @@index([merchantReference])
  @@index([status])
}

model Subscription {
  id               Int                @id @default(autoincrement())
  studentId        Int
  startDate        DateTime           @default(now())
  endDate          DateTime           // تاريخ الانتهاء المحسوب بدقة هندسية
  status           SubscriptionStatus @default(ACTIVE)
  totalPrice       Float
  subscriptionType SubscriptionType
  createdBy        Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // ✨ حقول التحكم الذكي والمطاطي في الحصص والكورسات المضافة حديثاً
  totalSessions    Int?               // إجمالي عدد الحصص المدفوعة (إجباري لو النوع PER_SESSION)
  usedSessions     Int                @default(0) // عداد الحصص المستهلكة فعلياً من الطالب
  durationMonths   Int?               // مدة الاشتراك بالشهور (لو النوع COURSE)

  student          Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdByUser    User?              @relation("CreatedSubscriptions", fields: [createdBy], references: [id])
  items            SubscriptionItem[]
}

model SubscriptionItem {
  id             Int          @id @default(autoincrement())
  subscriptionId Int
  sessionId      Int
  priceSnapshot  Float
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  session        Session      @relation(fields: [sessionId], references: [id])

  @@unique([subscriptionId, sessionId])
}

model WhatsAppWallet {
  id        Int                 @id @default(autoincrement())
  centerId  Int                 @unique
  balance   Int                 @default(0)
  updatedAt DateTime            @updatedAt
  center    Center              @relation(fields: [centerId], references: [id], onDelete: Cascade)
  transactions WhatsAppTransaction[]
}

model WhatsAppTransaction {
  id          Int                     @id @default(autoincrement())
  walletId    Int
  amount      Int
  type        WhatsAppTransactionType
  description String?
  paymentId   Int?
  createdAt   DateTime                @default(now())
  wallet      WhatsAppWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment     Payment?                @relation(fields: [paymentId], references: [id])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  centerId    Int
  userId      Int
  action      String
  targetType  String
  targetId    Int?
  details     String?
  createdAt   DateTime @default(now())
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

model Attendance {
  id             Int                      @id @default(autoincrement())
  studentId      Int
  sessionId      Int
  centerId       Int
  status         AttendanceStatus
  scannedAt      DateTime?
  markedAt       DateTime                 @default(now())
  autoMarked     Boolean                  @default(false)
  markedBySystem Boolean                  @default(false)
  lateMinutes    Int?
  windowId       Int?
  student        Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session        Session                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  center         Center                   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  window         SessionAttendanceWindow? @relation(fields: [windowId], references: [id])

  @@unique([studentId, windowId])
  @@index([sessionId])
  @@index([status])
}

model SessionAttendanceWindow {
  id               Int          @id @default(autoincrement())
  sessionId        Int
  date             DateTime
  openedAt         DateTime?
  closedAt         DateTime?
  isClosed         Boolean      @default(false)
  autoCloseMinutes Int          @default(10)
  manualClosedBy   Int?
  session          Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attendance       Attendance[]

  @@unique([sessionId, date])
  @@index([date])
  @@index([isClosed])
}

model AttendanceScan {
  id        Int      @id @default(autoincrement())
  studentId Int
  centerId  Int
  scannedAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([centerId])
  @@index([scannedAt])
}

model ShortLink {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  longUrl     String   @db.Text
  clicks      Int      @default(0)
  centerId    Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([centerId])
}

model PromoCode {
  id              Int          @id @default(autoincrement())
  code            String       @unique 
  discountPercent Float 
  durationMonths  Int          @default(1) 
  applicableCycle BillingCycle @default(BOTH) 
  maxUses         Int          @default(100) 
  usedCount       Int          @default(0) 
  expiresAt       DateTime 
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payments      Payment[] 
  activeCenters Center[]  @relation("CenterActivePromo") 

  @@index([code])
}

model SuperAdminGateway {
  id        Int      @id @default(autoincrement())
  token     String   @unique 
  isUsed    Boolean  @default(false)
  expiresAt DateTime 
  createdAt DateTime @default(now())
}

model SystemConfig {
  id               Int      @id @default(autoincrement())
  ownerName        String 
  masterPassphrase String 
  totpSecret       String? 
  updatedAt        DateTime @updatedAt
}